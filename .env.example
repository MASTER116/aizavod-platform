# ─── Database ───────────────────────────────────────
DATABASE_URL=                              # MySQL for prod, empty = SQLite

# ─── Backend ────────────────────────────────────────
BACKEND_BASE_URL=http://127.0.0.1:8000
BACKEND_API_KEY=                           # X-API-Key for bot -> backend auth

# ─── Admin Panel ────────────────────────────────────
ADMIN_PANEL_USER=admin
ADMIN_PANEL_PASSWORD=
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_EXPIRE_MINUTES=1440

# ─── Telegram Bot ───────────────────────────────────
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_IDS=                        # Comma-separated Telegram user IDs

# ─── AI: Image Generation (Replicate — FLUX 2 Pro) ─
REPLICATE_API_TOKEN=
FLUX_MODEL=black-forest-labs/flux-2-pro
KLING_MODEL=kling-ai/kling-v3
CHARACTER_LORA_URL=                        # Fine-tuned LoRA URL (optional)

# ─── AI: Text Generation (Claude / Anthropic) ──────
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ─── AI: Voice (Fish Audio S1) ─────────────────────
FISH_AUDIO_API_KEY=                        # Get at https://fish.audio
FISH_AUDIO_VOICE_ID=                       # Default voice ID (clone or preset)

# ─── AI: Music (Suno) ─────────────────────────────
SUNO_API_KEY=                              # Get at https://suno.com
SUNO_FREE_TIER=true                        # true = free tier, false = Pro

# ─── VK ────────────────────────────────────────────────
VK_ACCESS_TOKEN=
VK_GROUP_ID=
VK_API_VERSION=5.199

# ─── Instagram ──────────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=
INSTAGRAM_PROXY=                           # Optional: socks5://user:pass@host:port

# ─── Content Settings ──────────────────────────────
POSTS_PER_DAY=2
STORIES_PER_DAY=5
REELS_PER_WEEK=3
CAPTION_LANGUAGE=both                      # ru / en / both

# ─── Autonomy Toggles ──────────────────────────────
AUTO_GENERATE=false
AUTO_APPROVE=false
AUTO_PUBLISH=false
AUTO_REPLY_COMMENTS=false

# ─── Redis / Celery ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# ─── Logging ────────────────────────────────────────
LOG_LEVEL=INFO

# ─── CERTIFIER Agent ─────────────────────────────────
GROQ_API_KEY=
CERTIFIER_MODEL=llama-3.3-70b-versatile
CERTIFIER_KNOWLEDGE_DIR=data/certifier
